<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sprite Studio Mobile</title>
    <style>
        /* Modern Native Dark UI Stack */
        * { box-sizing: border-box; margin: 0; padding: 0; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; }
        body { background-color: #111827; color: #f3f4f6; min-height: 100vh; padding: 16px; display: flex; flex-direction: column; }
        
        header { text-align: center; margin-bottom: 24px; }
        header h1 { color: #818cf8; font-size: 1.5rem; font-weight: 700; letter-spacing: -0.025em; margin-bottom: 4px; }
        header p { color: #9ca3af; font-size: 0.875rem; }

        .workspace { max-width: 1200px; width: 100%; margin: 0 auto; display: grid; grid-template-columns: 1fr; gap: 24px; flex-grow: 1; align-items: start; }
        @media (min-width: 1024px) { .workspace { grid-template-columns: 1fr 2fr; } }

        .panel { background-color: #1f2937; padding: 20px; border-radius: 12px; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.3); display: flex; flex-direction: column; gap: 20px; }
        .panel-title { font-size: 1.125rem; font-weight: 600; border-bottom: 1px solid #374151; padding-bottom: 8px; color: #e5e7eb; }
        
        .upload-group { display: flex; flex-direction: column; gap: 12px; }
        .upload-card { background-color: #111827; padding: 12px; border-radius: 8px; border: 1px solid #374151; }
        
        .label-side { display: block; font-size: 0.75rem; font-weight: 700; margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.05em; color: #a5b4fc; }
        .label-front { display: block; font-size: 0.75rem; font-weight: 700; margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.05em; color: #6ee7b7; }
        input[type="file"] { width: 100%; font-size: 0.75rem; color: #9ca3af; cursor: pointer; }

        .slider-group { display: flex; flex-direction: column; gap: 16px; }
        .slider-wrapper { width: 100%; }
        .slider-header { display: flex; justify-content: space-between; font-size: 0.75rem; margin-bottom: 6px; color: #d1d5db; }
        .slider-header span:last-child { font-weight: 700; color: #818cf8; }
        input[type="range"] { width: 100%; height: 8px; border-radius: 4px; background: #374151; appearance: none; outline: none; cursor: pointer; }
        
        .btn-export { width: 100%; background-color: #059669; color: white; font-weight: 700; padding: 14px; border: none; border-radius: 8px; cursor: pointer; font-size: 0.875rem; transition: background 0.2s; min-height: 48px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.2); }
        .btn-export:hover { background-color: #10b981; }

        .viewport-stack { display: flex; flex-direction: column; gap: 24px; }
        
        .checkered-bg {
            background-color: #161b22;
            background-image: linear-gradient(45deg, #0d1117 25%, transparent 25%), linear-gradient(-45deg, #0d1117 25%, transparent 25%), linear-gradient(45deg, transparent 75%, #0d1117 75%), linear-gradient(-45deg, transparent 75%, #0d1117 75%);
            background-size: 16px 16px;
            background-position: 0 0, 0 8px, 8px -8px, -8px 0px;
            border-radius: 8px; border: 1px solid #374151; padding: 24px; display: flex; justify-content: center; align-items: center; width: 100%; overflow: auto;
        }

        .monitor-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; width: 100%; }
        @media (min-width: 640px) { .monitor-grid { grid-template-columns: repeat(4, 1fr); } }
        
        .monitor-card { background-color: rgba(17,24,39,0.9); padding: 12px; border-radius: 8px; border: 1px solid #1f2937; display: flex; flex-direction: column; align-items: center; width: 100%; box-shadow: inset 0 2px 4px 0 rgba(0, 0, 0, 0.6); }
        .monitor-card span { font-size: 10px; font-weight: 700; margin-top: 6px; text-transform: uppercase; text-align: center; }
        .text-side { color: #a5b4fc; }
        .text-front { color: #6ee7b7; }

        .view-label { font-size: 0.875rem; font-weight: 600; margin-bottom: 8px; align-self: flex-start; color: #d1d5db; display: block; }

        canvas { background-color: #0d1117; border-radius: 4px; border: 1px solid #1f2937; }
        .image-render-pixel { image-rendering: -moz-crisp-edges; image-rendering: -webkit-crisp-edges; image-rendering: pixelated; image-rendering: crisp-edges; }
    </style>
</head>
<body class="image-render-pixel">

    <header>
        <h1>Sprite Studio Mobile</h1>
        <p>Assemble, tweak, and generate modular 4-direction walk cycles</p>
    </header>

    <main class="workspace">
        
        <div class="panel">
            <h2 class="panel-title">1. Modular Layer Inputs</h2>
            <div class="upload-group">
                <div class="upload-card">
                    <label class="label-side">Side View: Torso & Head</label>
                    <input type="file" id="sideBodyUpload" accept="image/*">
                </div>
                <div class="upload-card">
                    <label class="label-side">Side View: Single Leg</label>
                    <input type="file" id="sideLegUpload" accept="image/*">
                </div>
                <div class="upload-card">
                    <label class="label-front">Front View: Torso & Head</label>
                    <input type="file" id="frontBodyUpload" accept="image/*">
                </div>
                <div class="upload-card">
                    <label class="label-front">Front View: Single Leg</label>
                    <input type="file" id="frontLegUpload" accept="image/*">
                </div>
            </div>

            <h2 class="panel-title">2. Kinematic Adjustments</h2>
            <div class="slider-group">
                <div class="slider-wrapper">
                    <div class="slider-header">
                        <span>Stride Range (Swing Extent)</span>
                        <span id="strideVal">0.4</span>
                    </div>
                    <input type="range" id="strideSlider" min="1" max="10" value="4">
                </div>
                <div class="slider-wrapper">
                    <div class="slider-header">
                        <span>Vertical Bounce (Body Bob)</span>
                        <span id="bounceVal">2.0</span>
                    </div>
                    <input type="range" id="bounceSlider" min="0" max="8" value="2">
                </div>
            </div>

            <button id="downloadBtn" class="btn-export">Export Sheet Image (PNG)</button>
        </div>

        <div class="viewport-stack">
            
            <div class="panel" style="align-items: center;">
                <h2 class="view-label">Live Animation Engine Monitor</h2>
                <div class="checkered-bg">
                    <div class="monitor-grid">
                        <div class="monitor-card">
                            <canvas id="previewCanvasRight" width="64" height="64" class="image-render-pixel" style="width:64px; height:64px;"></canvas>
                            <span class="text-side">Right (Row 0)</span>
                        </div>
                        <div class="monitor-card">
                            <canvas id="previewCanvasLeft" width="64" height="64" class="image-render-pixel" style="width:64px; height:64px;"></canvas>
                            <span class="text-side">Left (Row 1)</span>
                        </div>
                        <div class="monitor-card">
                            <canvas id="previewCanvasDown" width="64" height="64" class="image-render-pixel" style="width:64px; height:64px;"></canvas>
                            <span class="text-front">Down (Row 2)</span>
                        </div>
                        <div class="monitor-card">
                            <canvas id="previewCanvasUp" width="64" height="64" class="image-render-pixel" style="width:64px; height:64px;"></canvas>
                            <span class="text-front">Up (Row 3)</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="panel" style="align-items: center;">
                <h2 class="view-label">Generated Master Grid Output Canvas</h2>
                <div class="checkered-bg" style="min-height: 240px;">
                    <canvas id="walkCanvas" class="image-render-pixel" style="max-width: 100%; height: auto;"></canvas>
                </div>
            </div>

        </div>
    </main>

    <script>
        // Use standard event listener to block execution until DOM is 100% ready
        document.addEventListener("DOMContentLoaded", () => {
            const sheetCanvas = document.getElementById('walkCanvas');
            const sheetCtx = sheetCanvas.getContext('2d');
            
            const previews = {
                0: { canvas: document.getElementById('previewCanvasRight'), ctx: document.getElementById('previewCanvasRight').getContext('2d') },
                1: { canvas: document.getElementById('previewCanvasLeft'), ctx: document.getElementById('previewCanvasLeft').getContext('2d') },
                2: { canvas: document.getElementById('previewCanvasDown'), ctx: document.getElementById('previewCanvasDown').getContext('2d') },
                3: { canvas: document.getElementById('previewCanvasUp'), ctx: document.getElementById('previewCanvasUp').getContext('2d') }
            };

            const sideBodyUpload = document.getElementById('sideBodyUpload');
            const sideLegUpload = document.getElementById('sideLegUpload');
            const frontBodyUpload = document.getElementById('frontBodyUpload');
            const frontLegUpload = document.getElementById('frontLegUpload');
            const strideSlider = document.getElementById('strideSlider');
            const bounceSlider = document.getElementById('bounceSlider');
            const strideVal = document.getElementById('strideVal');
            const bounceVal = document.getElementById('bounceVal');
            const downloadBtn = document.getElementById('downloadBtn');

            const frameW = 64;
            const frameH = 64;
            const totalFrames = 8;
            const totalRows = 4;

            sheetCanvas.width = frameW * totalFrames;
            sheetCanvas.height = frameH * totalRows;

            let assets = { sideBody: null, sideLeg: null, frontBody: null, frontLeg: null };
            let strideMultiplier = 0.4;
            let bounceMultiplier = 2.0;

            let currentPlaybackFrame = 0;
            let lastFrameTimestamp = 0;
            const fpsPlaybackInterval = 1000 / 12;

            function createFallbackGraphic(width, height, baseHexColor, isBodyPerspective) {
                const tempCanvas = document.createElement('canvas');
                tempCanvas.width = width; tempCanvas.height = height;
                const tCtx = tempCanvas.getContext('2d');
                tCtx.fillStyle = baseHexColor; tCtx.fillRect(0, 0, width, height);
                if (isBodyPerspective) {
                    tCtx.fillStyle = '#ffffff'; tCtx.fillRect(width - 6, 4, 4, 4);
                }
                const imageObject = new Image();
                imageObject.src = tempCanvas.toDataURL();
                return imageObject;
            }

            // Safe initialization inside layout scope
            assets.sideBody = createFallbackGraphic(24, 32, '#3b82f6', true);
            assets.sideLeg = createFallbackGraphic(8, 20, '#ef4444', false);
            assets.frontBody = createFallbackGraphic(28, 32, '#10b981', false);
            assets.frontLeg = createFallbackGraphic(9, 20, '#f59e0b', false);

            strideSlider.addEventListener('input', (e) => {
                strideMultiplier = parseFloat(e.target.value) / 10;
                strideVal.textContent = strideMultiplier.toFixed(1);
                buildWalkCycle();
            });

            bounceSlider.addEventListener('input', (e) => {
                bounceMultiplier = parseFloat(e.target.value);
                bounceVal.textContent = bounceMultiplier.toFixed(1);
                buildWalkCycle();
            });

            function initializeFileUploader(fileInputElement, stateAssetKey) {
                fileInputElement.addEventListener('change', (e) => {
                    const targetFile = e.target.files[0];
                    if (!targetFile) return;
                    
                    const fileReader = new FileReader();
                    fileReader.onload = function(readerEvent) {
                        const clientImage = new Image();
                        clientImage.onload = function() {
                            assets[stateAssetKey] = clientImage;
                            buildWalkCycle();
                        };
                        clientImage.src = readerEvent.target.result;
                    };
                    fileReader.readAsDataURL(targetFile);
                });
            }

            initializeFileUploader(sideBodyUpload, 'sideBody');
            initializeFileUploader(sideLegUpload, 'sideLeg');
            initializeFileUploader(frontBodyUpload, 'frontBody');
            initializeFileUploader(frontLegUpload, 'frontLeg');

            function buildWalkCycle() {
                sheetCtx.clearRect(0, 0, sheetCanvas.width, sheetCanvas.height);

                for (let r = 0; r < totalRows; r++) {
                    for (let c = 0; c < totalFrames; c++) {
                        const fx = c * frameW;
                        const fy = r * frameH;
                        const linearProgress = c / totalFrames;
                        const angularRadian = linearProgress * Math.PI * 2;

                        sheetCtx.save();
                        sheetCtx.translate(fx + (frameW / 2), fy + (frameH / 2));

                        if (r === 0 || r === 1) {
                            if (r === 1) sheetCtx.scale(-1, 1);

                            const leg1Rot = Math.sin(angularRadian) * strideMultiplier;
                            const leg2Rot = Math.sin(angularRadian + Math.PI) * strideMultiplier;
                            const frameBodyBobY = Math.abs(Math.sin(angularRadian * 2)) * bounceMultiplier;

                            sheetCtx.save();
                            sheetCtx.translate(2, 2); sheetCtx.rotate(leg2Rot);
                            sheetCtx.drawImage(assets.sideLeg, -assets.sideLeg.width / 2, 0);
                            sheetCtx.restore();

                            sheetCtx.save();
                            sheetCtx.drawImage(assets.sideBody, -assets.sideBody.width / 2, -26 + frameBodyBobY);
                            sheetCtx.restore();

                            sheetCtx.save();
                            sheetCtx.translate(-4, 2); sheetCtx.rotate(leg1Rot);
                            sheetCtx.drawImage(assets.sideLeg, -assets.sideLeg.width / 2, 0);
                            sheetCtx.restore();

                        } else {
                            const leg1YTranslation = Math.sin(angularRadian) * (strideMultiplier * 8);
                            const leg2YTranslation = Math.sin(angularRadian + Math.PI) * (strideMultiplier * 8);
                            const frameBodyBobY = Math.abs(Math.sin(angularRadian * 2)) * (bounceMultiplier * 0.75);

                            const facingAwayPerspective = (r === 3);

                            if (!facingAwayPerspective) {
                                processFrontLegLayout(leg1YTranslation, leg2YTranslation);
                                processFrontTorsoLayout(frameBodyBobY);
                            } else {
                                processFrontTorsoLayout(frameBodyBobY);
                                processFrontLegLayout(leg1YTranslation, leg2YTranslation);
                            }
                        }
                        sheetCtx.restore();
                    }
                }
            }

            function processFrontLegLayout(leftLegY, rightLegY) {
                sheetCtx.save(); sheetCtx.translate(-6, 2 + leftLegY);
                sheetCtx.drawImage(assets.frontLeg, -assets.frontLeg.width / 2, 0); sheetCtx.restore();
                
                sheetCtx.save(); sheetCtx.translate(6, 2 + rightLegY);
                sheetCtx.drawImage(assets.frontLeg, -assets.frontLeg.width / 2, 0); sheetCtx.restore();
            }

            function processFrontTorsoLayout(bobYValue) {
                sheetCtx.save(); 
                sheetCtx.drawImage(assets.frontBody, -assets.frontBody.width / 2, -26 + bobYValue); 
                sheetCtx.restore();
            }

            function renderMonitorLoop(timestamp) {
                requestAnimationFrame(renderMonitorLoop);

                const dynamicDeltaTime = timestamp - lastFrameTimestamp;
                if (dynamicDeltaTime < fpsPlaybackInterval) return;
                lastFrameTimestamp = timestamp - (dynamicDeltaTime % fpsPlaybackInterval);

                for (let targetRow = 0; targetRow < totalRows; targetRow++) {
                    const targetMonitor = previews[targetRow];
                    targetMonitor.ctx.clearRect(0, 0, frameW, frameH);

                    const sourceXOffset = currentPlaybackFrame * frameW;
                    const sourceYOffset = targetRow * frameH;

                    targetMonitor.ctx.drawImage(
                        sheetCanvas,
                        sourceXOffset, sourceYOffset, frameW, frameH,
                        0, 0, frameW, frameH
                    );
                }

                currentPlaybackFrame = (currentPlaybackFrame + 1) % totalFrames;
            }

            downloadBtn.addEventListener('click', () => {
                const clickTriggerLink = document.createElement('a');
                clickTriggerLink.download = 'modular_walkcycle_sheet.png';
                clickTriggerLink.href = sheetCanvas.toDataURL('image/png');
                clickTriggerLink.click();
            });

            // Trigger initial loop kickstarts safely
            buildWalkCycle(); 
            requestAnimationFrame(renderMonitorLoop);
        });
    </script>
</body>
</html>
