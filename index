<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sprite Studio Mobile</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-900 text-gray-100 min-h-screen flex flex-col p-4 select-none">

    <header class="mb-6 text-center">
        <h1 class="text-2xl font-bold text-indigo-400 tracking-tight">Sprite Studio Mobile</h1>
        <p class="text-sm text-gray-400">Assemble, tweak, and generate modular 4-direction walk cycles</p>
    </header>

    <main class="max-w-6xl mx-auto w-full grid grid-cols-1 lg:grid-cols-3 gap-6 flex-grow items-start">
        
        <div class="bg-gray-800 p-5 rounded-xl shadow-xl flex flex-col gap-5">
            <h2 class="text-lg font-semibold border-b border-gray-700 pb-2 text-gray-200">1. Modular Layer Inputs</h2>
            
            <div class="space-y-3">
                <div class="bg-gray-900 p-3 rounded-lg border border-gray-700">
                    <label class="block text-xs font-bold mb-1 text-indigo-300 uppercase tracking-wider">Side View: Torso & Head</label>
                    <input type="file" id="sideBodyUpload" accept="image/*" class="w-full text-xs text-gray-400 file:mr-2 file:py-1 file:px-2 file:rounded file:border-0 file:bg-indigo-600 file:text-white file:font-semibold cursor-pointer">
                </div>
                <div class="bg-gray-900 p-3 rounded-lg border border-gray-700">
                    <label class="block text-xs font-bold mb-1 text-indigo-300 uppercase tracking-wider">Side View: Single Leg</label>
                    <input type="file" id="sideLegUpload" accept="image/*" class="w-full text-xs text-gray-400 file:mr-2 file:py-1 file:px-2 file:rounded file:border-0 file:bg-indigo-600 file:text-white file:font-semibold cursor-pointer">
                </div>
                
                <div class="bg-gray-900 p-3 rounded-lg border border-gray-700">
                    <label class="block text-xs font-bold mb-1 text-emerald-300 uppercase tracking-wider">Front View: Torso & Head</label>
                    <input type="file" id="frontBodyUpload" accept="image/*" class="w-full text-xs text-gray-400 file:mr-2 file:py-1 file:px-2 file:rounded file:border-0 file:bg-emerald-600 file:text-white file:font-semibold cursor-pointer">
                </div>
                <div class="bg-gray-900 p-3 rounded-lg border border-gray-700">
                    <label class="block text-xs font-bold mb-1 text-emerald-300 uppercase tracking-wider">Front View: Single Leg</label>
                    <input type="file" id="frontLegUpload" accept="image/*" class="w-full text-xs text-gray-400 file:mr-2 file:py-1 file:px-2 file:rounded file:border-0 file:bg-emerald-600 file:text-white file:font-semibold cursor-pointer">
                </div>
            </div>

            <h2 class="text-lg font-semibold border-b border-gray-700 pb-2 mt-2 text-gray-200">2. Kinematic Adjustments</h2>
            <div class="space-y-4">
                <div>
                    <div class="flex justify-between items-center mb-1">
                        <label class="text-xs font-medium text-gray-300">Stride Range (Swing Extent)</label>
                        <span id="strideVal" class="text-xs font-bold text-indigo-400">0.4</span>
                    </div>
                    <input type="range" id="strideSlider" min="1" max="10" value="4" class="w-full accent-indigo-500 cursor-pointer h-2 bg-gray-700 rounded-lg appearance-none">
                </div>
                <div>
                    <div class="flex justify-between items-center mb-1">
                        <label class="text-xs font-medium text-gray-300">Vertical Bounce (Body Bob)</label>
                        <span id="bounceVal" class="text-xs font-bold text-indigo-400">2.0</span>
                    </div>
                    <input type="range" id="bounceSlider" min="0" max="8" value="2" class="w-full accent-indigo-500 cursor-pointer h-2 bg-gray-700 rounded-lg appearance-none">
                </div>
            </div>

            <button id="downloadBtn" class="w-full bg-emerald-600 hover:bg-emerald-500 active:bg-emerald-700 text-white font-bold py-3.5 px-4 rounded-lg transition mt-4 shadow-lg min-h-[48px] text-sm tracking-wide">
                Export Sheet Image (PNG)
            </button>
        </div>

        <div class="lg:col-span-2 flex flex-col gap-6">
            
            <div class="bg-gray-800 p-4 rounded-xl shadow-xl flex flex-col items-center">
                <h2 class="text-md font-semibold mb-2 self-start text-gray-300">Live Animation Engine Monitor</h2>
                <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 items-center justify-items-center bg-gray-950 p-6 rounded-lg border border-gray-700 w-full checkered-bg">
                    
                    <div class="flex flex-col items-center bg-gray-900/90 p-3 rounded-lg border border-gray-800 shadow-inner w-full">
                        <canvas id="previewCanvasRight" width="64" height="64" class="w-16 h-16 bg-gray-950 rounded border border-gray-800 object-contain image-render-pixel"></canvas>
                        <span class="text-[10px] text-indigo-300 font-bold mt-1.5 uppercase text-center">Right (Row 0)</span>
                    </div>

                    <div class="flex flex-col items-center bg-gray-900/90 p-3 rounded-lg border border-gray-800 shadow-inner w-full">
                        <canvas id="previewCanvasLeft" width="64" height="64" class="w-16 h-16 bg-gray-950 rounded border border-gray-800 object-contain image-render-pixel"></canvas>
                        <span class="text-[10px] text-indigo-300 font-bold mt-1.5 uppercase text-center">Left (Row 1)</span>
                    </div>

                    <div class="flex flex-col items-center bg-gray-900/90 p-3 rounded-lg border border-gray-800 shadow-inner w-full">
                        <canvas id="previewCanvasDown" width="64" height="64" class="w-16 h-16 bg-gray-950 rounded border border-gray-800 object-contain image-render-pixel"></canvas>
                        <span class="text-[10px] text-emerald-300 font-bold mt-1.5 uppercase text-center">Down (Row 2)</span>
                    </div>

                    <div class="flex flex-col items-center bg-gray-900/90 p-3 rounded-lg border border-gray-800 shadow-inner w-full">
                        <canvas id="previewCanvasUp" width="64" height="64" class="w-16 h-16 bg-gray-950 rounded border border-gray-800 object-contain image-render-pixel"></canvas>
                        <span class="text-[10px] text-emerald-300 font-bold mt-1.5 uppercase text-center">Up (Row 3)</span>
                    </div>

                </div>
            </div>

            <div class="bg-gray-800 p-4 rounded-xl shadow-xl flex flex-col items-center">
                <h2 class="text-md font-semibold mb-2 self-start text-gray-300">Generated Master Grid Output Canvas</h2>
                <div class="w-full overflow-auto bg-gray-950 p-4 rounded-lg border border-gray-700 flex justify-center items-center checkered-bg min-h-[240px]">
                    <canvas id="walkCanvas" class="max-w-full h-auto shadow-2xl image-render-pixel"></canvas>
                </div>
            </div>

        </div>
    </main>

    <style>
        .checkered-bg {
            background-image: linear-gradient(45deg, #0d1117 25%, transparent 25%), linear-gradient(-45deg, #0d1117 25%, transparent 25%), linear-gradient(45deg, transparent 75%, #0d1117 75%), linear-gradient(-45deg, transparent 75%, #0d1117 75%);
            background-size: 16px 16px;
            background-position: 0 0, 0 8px, 8px -8px, -8px 0px;
            background-color: #161b22;
        }
        .image-render-pixel {
            image-rendering: -moz-crisp-edges;
            image-rendering: -webkit-crisp-edges;
            image-rendering: pixelated;
            image-rendering: crisp-edges;
        }
    </style>

    <script>
        const sheetCanvas = document.getElementById('walkCanvas');
        const sheetCtx = sheetCanvas.getContext('2d');
        
        const previews = {
            0: { canvas: document.getElementById('previewCanvasRight'), ctx: document.getElementById('previewCanvasRight').getContext('2d') },
            1: { canvas: document.getElementById('previewCanvasLeft'), ctx: document.getElementById('previewCanvasLeft').getContext('2d') },
            2: { canvas: document.getElementById('previewCanvasDown'), ctx: document.getElementById('previewCanvasDown').getContext('2d') },
            3: { canvas: document.getElementById('previewCanvasUp'), ctx: document.getElementById('previewCanvasUp').getContext('2d') }
        };

        const sideBodyUpload = document.getElementById('sideBodyUpload');
        const sideLegUpload = document.getElementById('sideLegUpload');
        const frontBodyUpload = document.getElementById('frontBodyUpload');
        const frontLegUpload = document.getElementById('frontLegUpload');
        const strideSlider = document.getElementById('strideSlider');
        const bounceSlider = document.getElementById('bounceSlider');
        const strideVal = document.getElementById('strideVal');
        const bounceVal = document.getElementById('bounceVal');
        const downloadBtn = document.getElementById('downloadBtn');

        const frameW = 64;
        const frameH = 64;
        const totalFrames = 8;
        const totalRows = 4;

        sheetCanvas.width = frameW * totalFrames;
        sheetCanvas.height = frameH * totalRows;

        let assets = { sideBody: null, sideLeg: null, frontBody: null, frontLeg: null };

        let strideMultiplier = 0.4;
        let bounceMultiplier = 2.0;

        let currentPlaybackFrame = 0;
        let lastFrameTimestamp = 0;
        const fpsPlaybackInterval = 1000 / 12;

        function createFallbackGraphic(width, height, baseHexColor, isBodyPerspective) {
            const tempCanvas = document.createElement('canvas');
            tempCanvas.width = width; tempCanvas.height = height;
            const tCtx = tempCanvas.getContext('2d');
            tCtx.fillStyle = baseHexColor; tCtx.fillRect(0, 0, width, height);
            if (isBodyPerspective) {
                tCtx.fillStyle = '#ffffff'; tCtx.fillRect(width - 6, 4, 4, 4);
            }
            const imageObject = new Image();
            imageObject.src = tempCanvas.toDataURL();
            return imageObject;
        }

        assets.sideBody = createFallbackGraphic(24, 32, '#3b82f6', true);
        assets.sideLeg = createFallbackGraphic(8, 20, '#ef4444', false);
        assets.frontBody = createFallbackGraphic(28, 32, '#10b981', false);
        assets.frontLeg = createFallbackGraphic(9, 20, '#f59e0b', false);

        window.onload = () => { 
            buildWalkCycle(); 
            requestAnimationFrame(renderMonitorLoop); 
        };

        strideSlider.addEventListener('input', (e) => {
            strideMultiplier = parseFloat(e.target.value) / 10;
            strideVal.textContent = strideMultiplier.toFixed(1);
            buildWalkCycle();
        });

        bounceSlider.addEventListener('input', (e) => {
            bounceMultiplier = parseFloat(e.target.value);
            bounceVal.textContent = bounceMultiplier.toFixed(1);
            buildWalkCycle();
        });

        function initializeFileUploader(fileInputElement, stateAssetKey) {
            fileInputElement.addEventListener('change', (e) => {
                const targetFile = e.target.files[0];
                if (!targetFile) return;
                
                const fileReader = new FileReader();
                fileReader.onload = function(readerEvent) {
                    const clientImage = new Image();
                    clientImage.onload = function() {
                        assets[stateAssetKey] = clientImage;
                        buildWalkCycle();
                    };
                    clientImage.src = readerEvent.target.result;
                };
                fileReader.readAsDataURL(targetFile);
            });
        }

        initializeFileUploader(sideBodyUpload, 'sideBody');
        initializeFileUploader(sideLegUpload, 'sideLeg');
        initializeFileUploader(frontBodyUpload, 'frontBody');
        initializeFileUploader(frontLegUpload, 'frontLeg');

        function buildWalkCycle() {
            sheetCtx.clearRect(0, 0, sheetCanvas.width, sheetCanvas.height);

            for (let r = 0; r < totalRows; r++) {
                for (let c = 0; c < totalFrames; c++) {
                    const fx = c * frameW;
                    const fy = r * frameH;
                    const linearProgress = c / totalFrames;
                    const angularRadian = linearProgress * Math.PI * 2;

                    sheetCtx.save();
                    sheetCtx.translate(fx + (frameW / 2), fy + (frameH / 2));

                    if (r === 0 || r === 1) {
                        if (r === 1) sheetCtx.scale(-1, 1);

                        const leg1Rot = Math.sin(angularRadian) * strideMultiplier;
                        const leg2Rot = Math.sin(angularRadian + Math.PI) * strideMultiplier;
                        const frameBodyBobY = Math.abs(Math.sin(angularRadian * 2)) * bounceMultiplier;

                        sheetCtx.save();
                        sheetCtx.translate(2, 2); sheetCtx.rotate(leg2Rot);
                        sheetCtx.drawImage(assets.sideLeg, -assets.sideLeg.width / 2, 0);
                        sheetCtx.restore();

                        sheetCtx.save();
                        sheetCtx.drawImage(assets.sideBody, -assets.sideBody.width / 2, -26 + frameBodyBobY);
                        sheetCtx.restore();

                        sheetCtx.save();
                        sheetCtx.translate(-4, 2); sheetCtx.rotate(leg1Rot);
                        sheetCtx.drawImage(assets.sideLeg, -assets.sideLeg.width / 2, 0);
                        sheetCtx.restore();

                    } else {
                        const leg1YTranslation = Math.sin(angularRadian) * (strideMultiplier * 8);
                        const leg2YTranslation = Math.sin(angularRadian + Math.PI) * (strideMultiplier * 8);
                        const frameBodyBobY = Math.abs(Math.sin(angularRadian * 2)) * (bounceMultiplier * 0.75);

                        const facingAwayPerspective = (r === 3);

                        if (!facingAwayPerspective) {
                            processFrontLegLayout(leg1YTranslation, leg2YTranslation);
                            processFrontTorsoLayout(frameBodyBobY);
                        } else {
                            processFrontTorsoLayout(frameBodyBobY);
                            processFrontLegLayout(leg1YTranslation, leg2YTranslation);
                        }
                    }
                    sheetCtx.restore();
                }
            }
        }

        function processFrontLegLayout(leftLegY, rightLegY) {
            sheetCtx.save(); sheetCtx.translate(-6, 2 + leftLegY);
            sheetCtx.drawImage(assets.frontLeg, -assets.frontLeg.width / 2, 0); sheetCtx.restore();
            
            sheetCtx.save(); sheetCtx.translate(6, 2 + rightLegY);
            sheetCtx.drawImage(assets.frontLeg, -assets.frontLeg.width / 2, 0); sheetCtx.restore();
        }

        function processFrontTorsoLayout(bobYValue) {
            sheetCtx.save(); 
            sheetCtx.drawImage(assets.frontBody, -assets.frontBody.width / 2, -26 + bobYValue); 
            sheetCtx.restore();
        }

        function renderMonitorLoop(timestamp) {
            requestAnimationFrame(renderMonitorLoop);

            const dynamicDeltaTime = timestamp - lastFrameTimestamp;
            if (dynamicDeltaTime < fpsPlaybackInterval) return;
            lastFrameTimestamp = timestamp - (dynamicDeltaTime % fpsPlaybackInterval);

            for (let targetRow = 0; targetRow < totalRows; targetRow++) {
                const targetMonitor = previews[targetRow];
                targetMonitor.ctx.clearRect(0, 0, frameW, frameH);

                const sourceXOffset = currentPlaybackFrame * frameW;
                const sourceYOffset = targetRow * frameH;

                targetMonitor.ctx.drawImage(
                    sheetCanvas,
                    sourceXOffset, sourceYOffset, frameW, frameH,
                    0, 0, frameW, frameH
                );
            }

            currentPlaybackFrame = (currentPlaybackFrame + 1) % totalFrames;
        }

        downloadBtn.addEventListener('click', () => {
            const clickTriggerLink = document.createElement('a');
            clickTriggerLink.download = 'modular_walkcycle_sheet.png';
            clickTriggerLink.href = sheetCanvas.toDataURL('image/png');
            clickTriggerLink.click();
        });
    </script>
</body>
</html>
